        <mxCell id="table_couriers" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;fillColor=none;strokeColor=none;" value="&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;width:100%; border-collapse: collapse; text-align: left;&quot;&gt; &lt;thead&gt; &lt;tr&gt;&lt;th colspan=&quot;4&quot; style=&quot;text-align: center; background-color: rgb(240, 240, 240);&quot;&gt;Couriers&lt;/th&gt;&lt;/tr&gt; &lt;tr style=&quot;background-color: rgb(250, 250, 250);&quot;&gt;&lt;th&gt;Атрибут&lt;/th&gt;&lt;th&gt;Описание&lt;/th&gt;&lt;th&gt;Тип&lt;/th&gt;&lt;th&gt;Ограничения&lt;/th&gt;&lt;/tr&gt; &lt;/thead&gt; &lt;tbody&gt; &lt;tr&gt;&lt;td&gt;&lt;b&gt;courier_id&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Идентификатор курьера&lt;/td&gt;&lt;td&gt;SERIAL&lt;/td&gt;&lt;td&gt;PRIMARY KEY&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;first_name&lt;/td&gt;&lt;td&gt;Имя&lt;/td&gt;&lt;td&gt;VARCHAR(100)&lt;/td&gt;&lt;td&gt;NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;last_name&lt;/td&gt;&lt;td&gt;Фамилия&lt;/td&gt;&lt;td&gt;VARCHAR(100)&lt;/td&gt;&lt;td&gt;NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;gender&lt;/td&gt;&lt;td&gt;Пол&lt;/td&gt;&lt;td&gt;VARCHAR(10)&lt;/td&gt;&lt;td&gt;IN (&#39;male&#39;, &#39;female&#39;)&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;birth_date&lt;/td&gt;&lt;td&gt;Дата рождения&lt;/td&gt;&lt;td&gt;DATE&lt;/td&gt;&lt;td&gt;NOT NULL, &amp;lt;= CURRENT_DATE - INTERVAL &#39;18 years&#39;&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;phone&lt;/td&gt;&lt;td&gt;Номер телефона&lt;/td&gt;&lt;td&gt;VARCHAR(20)&lt;/td&gt;&lt;td&gt;UNIQUE, NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;experience&lt;/td&gt;&lt;td&gt;Опыт работы&lt;/td&gt;&lt;td&gt;NUMERIC&lt;/td&gt;&lt;td&gt;&amp;gt;= 0, DEFAULT 0&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;orders_cnt&lt;/td&gt;&lt;td&gt;Кол-во выполненных заказов&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;&amp;gt;= 0, DEFAULT 0&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;rating&lt;/td&gt;&lt;td&gt;Рейтинг курьера&lt;/td&gt;&lt;td&gt;NUMERIC&lt;/td&gt;&lt;td&gt;&amp;gt;= 0, &amp;lt;= 5, DEFAULT 0&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;total_fine&lt;/td&gt;&lt;td&gt;Общая сумма штрафов&lt;/td&gt;&lt;td&gt;DECIMAL&lt;/td&gt;&lt;td&gt;&amp;gt;= 0, DEFAULT 0&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;total_bonus&lt;/td&gt;&lt;td&gt;Общая сумма бонусов&lt;/td&gt;&lt;td&gt;DECIMAL&lt;/td&gt;&lt;td&gt;&amp;gt;= 0, DEFAULT 0&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;transport_id&lt;/td&gt;&lt;td&gt;ID используемого транспорта&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Transport)&lt;/td&gt;&lt;/tr&gt; &lt;/tbody&gt; &lt;/table&gt;" vertex="1">
          <mxGeometry height="440" width="750" x="800" y="700" as="geometry" />
        </mxCell>
        <mxCell id="table_logs" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;fillColor=none;strokeColor=none;" value="&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;width:100%; border-collapse: collapse; text-align: left;&quot;&gt; &lt;thead&gt; &lt;tr&gt;&lt;th colspan=&quot;4&quot; style=&quot;text-align: center; background-color: rgb(240, 240, 240);&quot;&gt;Delivery_logs&lt;/th&gt;&lt;/tr&gt; &lt;tr style=&quot;background-color: rgb(250, 250, 250);&quot;&gt;&lt;th&gt;Атрибут&lt;/th&gt;&lt;th&gt;Описание&lt;/th&gt;&lt;th&gt;Тип&lt;/th&gt;&lt;th&gt;Ограничения&lt;/th&gt;&lt;/tr&gt; &lt;/thead&gt; &lt;tbody&gt; &lt;tr&gt;&lt;td&gt;&lt;b&gt;log_id&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Идентификатор записи&lt;/td&gt;&lt;td&gt;SERIAL&lt;/td&gt;&lt;td&gt;PRIMARY KEY&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;order_id&lt;/td&gt;&lt;td&gt;ID заказа&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Orders), NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;courier_id&lt;/td&gt;&lt;td&gt;ID курьера&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Couriers), NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;transport_id&lt;/td&gt;&lt;td&gt;ID транспорта&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Transport)&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;stage_type&lt;/td&gt;&lt;td&gt;Тип этапа (транзит/доставка)&lt;/td&gt;&lt;td&gt;VARCHAR(50)&lt;/td&gt;&lt;td&gt;NOT NULL, IN (transit, delivery)&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;src_wh_id&lt;/td&gt;&lt;td&gt;Склад отправления&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Warehouse)&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;dst_wh_id&lt;/td&gt;&lt;td&gt;Склад назначения&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Warehouse)&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;dest_addr&lt;/td&gt;&lt;td&gt;Адрес конечной доставки&lt;/td&gt;&lt;td&gt;VARCHAR(255)&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;receive_dt&lt;/td&gt;&lt;td&gt;Время получения груза курьером&lt;/td&gt;&lt;td&gt;TIMESTAMP&lt;/td&gt;&lt;td&gt;&amp;lt; plan_dt, &amp;lt; actual_dt&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;plan_dt&lt;/td&gt;&lt;td&gt;Плановое время прибытия&lt;/td&gt;&lt;td&gt;TIMESTAMP&lt;/td&gt;&lt;td&gt;NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;actual_dt&lt;/td&gt;&lt;td&gt;Фактическое время прибытия&lt;/td&gt;&lt;td&gt;TIMESTAMP&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;stage_status&lt;/td&gt;&lt;td&gt;Статус этапа&lt;/td&gt;&lt;td&gt;VARCHAR(50)&lt;/td&gt;&lt;td&gt;NOT NULL, IN (pending, in_progress, completed, canceled)&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;&lt;br&gt;&lt;/td&gt;&lt;td&gt;Условие валидации этапа&lt;/td&gt;&lt;td&gt;&lt;br&gt;&lt;/td&gt;&lt;td&gt;(stage_type=&#39;transit&#39; AND dst_wh_id IS NOT NULL) OR &lt;br&gt;(stage_type=&#39;delivery&#39; AND dest_addr IS NOT NULL)&lt;/td&gt;&lt;/tr&gt; &lt;/tbody&gt; &lt;/table&gt;" vertex="1">
          <mxGeometry height="480" width="750" x="20" y="350" as="geometry" />
        </mxCell>
        <mxCell id="table_transport" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;fillColor=none;strokeColor=none;" value="&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;width:100%; border-collapse: collapse; text-align: left;&quot;&gt; &lt;thead&gt; &lt;tr&gt;&lt;th colspan=&quot;4&quot; style=&quot;text-align: center; background-color: rgb(240, 240, 240);&quot;&gt;Transport&lt;/th&gt;&lt;/tr&gt; &lt;tr style=&quot;background-color: rgb(250, 250, 250);&quot;&gt;&lt;th&gt;Атрибут&lt;/th&gt;&lt;th&gt;Описание&lt;/th&gt;&lt;th&gt;Тип&lt;/th&gt;&lt;th&gt;Ограничения&lt;/th&gt;&lt;/tr&gt; &lt;/thead&gt; &lt;tbody&gt; &lt;tr&gt;&lt;td&gt;&lt;b&gt;transport_id&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Идентификатор транспорта&lt;/td&gt;&lt;td&gt;SERIAL&lt;/td&gt;&lt;td&gt;PRIMARY KEY&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;transport_name&lt;/td&gt;&lt;td&gt;Наименование/модель&lt;/td&gt;&lt;td&gt;VARCHAR(100)&lt;/td&gt;&lt;td&gt;NOT NULL, UNIQUE&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;transport_type&lt;/td&gt;&lt;td&gt;Тип транспортного средства&lt;/td&gt;&lt;td&gt;VARCHAR(50)&lt;/td&gt;&lt;td&gt;NOT NULL, IN (ship, plane, truck, van, car, scooter, bicycle)&lt;br&gt;&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;payload_capacity&lt;/td&gt;&lt;td&gt;Грузоподъемность&lt;/td&gt;&lt;td&gt;NUMERIC&lt;/td&gt;&lt;td&gt;&amp;gt; 0, NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;cost_per_km&lt;/td&gt;&lt;td&gt;Стоимость за километр&lt;/td&gt;&lt;td&gt;DECIMAL&lt;/td&gt;&lt;td&gt;&amp;gt;= 0, NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;units_cnt&lt;/td&gt;&lt;td&gt;Количество единиц в автопарке&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;&amp;gt;= 0, NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;/tbody&gt; &lt;/table&gt;" vertex="1">
          <mxGeometry height="260" width="750" x="800" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="table_finances" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;fillColor=none;strokeColor=none;" value="&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;width:100%; border-collapse: collapse; text-align: left;&quot;&gt; &lt;thead&gt; &lt;tr&gt;&lt;th colspan=&quot;4&quot; style=&quot;text-align: center; background-color: rgb(240, 240, 240);&quot;&gt;Finances&lt;/th&gt;&lt;/tr&gt; &lt;tr style=&quot;background-color: rgb(250, 250, 250);&quot;&gt;&lt;th&gt;Атрибут&lt;/th&gt;&lt;th&gt;Описание&lt;/th&gt;&lt;th&gt;Тип&lt;/th&gt;&lt;th&gt;Ограничения&lt;/th&gt;&lt;/tr&gt; &lt;/thead&gt; &lt;tbody&gt; &lt;tr&gt;&lt;td&gt;&lt;b&gt;operation_id&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Идентификатор операции&lt;/td&gt;&lt;td&gt;SERIAL&lt;/td&gt;&lt;td&gt;PRIMARY KEY&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;courier_id&lt;/td&gt;&lt;td&gt;ID курьера&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Couriers), NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;order_id&lt;/td&gt;&lt;td&gt;ID заказа&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Orders), NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;log_id&lt;/td&gt;&lt;td&gt;ID записи лога доставки&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Delivery_logs), NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;operation_type&lt;/td&gt;&lt;td&gt;Тип операции (бонус/штраф)&lt;/td&gt;&lt;td&gt;VARCHAR(50)&lt;/td&gt;&lt;td&gt;NOT NULL, IN (bonus, fine)&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;amount&lt;/td&gt;&lt;td&gt;Сумма операции&lt;/td&gt;&lt;td&gt;DECIMAL&lt;/td&gt;&lt;td&gt;NOT NULL, &amp;gt;0&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;created_time&lt;/td&gt;&lt;td&gt;Дата и время записи&lt;/td&gt;&lt;td&gt;TIMESTAMP&lt;/td&gt;&lt;td&gt;NOT NULL,&amp;nbsp;DEFAULT CURRENT_TIMESTAMP&lt;/td&gt;&lt;/tr&gt; &lt;/tbody&gt; &lt;/table&gt;" vertex="1">
