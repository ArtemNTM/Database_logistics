        <mxCell id="table_warehouse" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;fillColor=none;strokeColor=none;" value="&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;width:100%; border-collapse: collapse; text-align: left;&quot;&gt; &lt;thead&gt; &lt;tr&gt;&lt;th colspan=&quot;4&quot; style=&quot;text-align: center; background-color: rgb(240, 240, 240);&quot;&gt;Warehouse&lt;/th&gt;&lt;/tr&gt; &lt;tr style=&quot;background-color: rgb(250, 250, 250);&quot;&gt;&lt;th&gt;Атрибут&lt;/th&gt;&lt;th&gt;Описание&lt;/th&gt;&lt;th&gt;Тип&lt;/th&gt;&lt;th&gt;Ограничения&lt;/th&gt;&lt;/tr&gt; &lt;/thead&gt; &lt;tbody&gt; &lt;tr&gt;&lt;td&gt;&lt;b&gt;warehouse_id&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Идентификатор склада&lt;/td&gt;&lt;td&gt;SERIAL&lt;/td&gt;&lt;td&gt;PRIMARY KEY&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;city&lt;/td&gt;&lt;td&gt;Город расположения&lt;/td&gt;&lt;td&gt;VARCHAR(100)&lt;/td&gt;&lt;td&gt;NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;street&lt;/td&gt;&lt;td&gt;Улица&lt;/td&gt;&lt;td&gt;VARCHAR(255)&lt;/td&gt;&lt;td&gt;NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;building&lt;/td&gt;&lt;td&gt;Номер здания/строения&lt;/td&gt;&lt;td&gt;VARCHAR(10)&lt;/td&gt;&lt;td&gt;NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;capacity&lt;/td&gt;&lt;td&gt;Общая вместимость&lt;/td&gt;&lt;td&gt;DECIMAL(10,2)&lt;/td&gt;&lt;td&gt;&amp;gt; 0, NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;current_load&lt;/td&gt;&lt;td&gt;Текущая загруженность&lt;/td&gt;&lt;td&gt;DECIMAL(10,2)&lt;/td&gt;&lt;td&gt;&amp;gt;= 0, &amp;lt;= capacity , DEFAULT 0&lt;/td&gt;&lt;/tr&gt; &lt;/tbody&gt; &lt;/table&gt;" vertex="1">
