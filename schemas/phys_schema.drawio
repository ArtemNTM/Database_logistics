        <mxCell id="table_clients" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;fillColor=none;strokeColor=none;" value="&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;width:100%; border-collapse: collapse; text-align: left;&quot;&gt; &lt;thead&gt; &lt;tr&gt;&lt;th colspan=&quot;4&quot; style=&quot;text-align: center; background-color: rgb(240, 240, 240);&quot;&gt;Clients&lt;/th&gt;&lt;/tr&gt; &lt;tr style=&quot;background-color: rgb(250, 250, 250);&quot;&gt;&lt;th&gt;Атрибут&lt;/th&gt;&lt;th&gt;Описание&lt;/th&gt;&lt;th&gt;Тип&lt;/th&gt;&lt;th&gt;Ограничения&lt;/th&gt;&lt;/tr&gt; &lt;/thead&gt; &lt;tbody&gt; &lt;tr&gt;&lt;td&gt;&lt;b&gt;client_id&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Идентификатор клиента&lt;/td&gt;&lt;td&gt;SERIAL&lt;/td&gt;&lt;td&gt;PRIMARY KEY&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;first_name&lt;/td&gt;&lt;td&gt;Имя&lt;/td&gt;&lt;td&gt;VARCHAR(100)&lt;/td&gt;&lt;td&gt;NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;last_name&lt;/td&gt;&lt;td&gt;Фамилия&lt;/td&gt;&lt;td&gt;VARCHAR(100)&lt;/td&gt;&lt;td&gt;NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;birth_date&lt;/td&gt;&lt;td&gt;Дата рождения&lt;/td&gt;&lt;td&gt;DATE&lt;/td&gt;&lt;td&gt;&amp;lt;= CURRENT_DATE, NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;city&lt;/td&gt;&lt;td&gt;Город проживания&lt;/td&gt;&lt;td&gt;VARCHAR(100)&lt;/td&gt;&lt;td&gt;NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;phone&lt;/td&gt;&lt;td&gt;Номер телефона&lt;/td&gt;&lt;td&gt;VARCHAR(20)&lt;/td&gt;&lt;td&gt;UNIQUE, NOT NULL,&amp;nbsp;CHECK(~ &#39;^8[0-9]{10}$&#39;)&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;email&lt;/td&gt;&lt;td&gt;Адрес электронной почты&lt;/td&gt;&lt;td&gt;VARCHAR(255)&lt;/td&gt;&lt;td&gt;UNIQUE,&amp;nbsp;CHECK(LIKE &#39;%@%&#39;)&lt;/td&gt;&lt;/tr&gt; &lt;/tbody&gt; &lt;/table&gt;" vertex="1">
