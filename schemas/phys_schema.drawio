        <mxCell id="table_orders" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;fillColor=none;strokeColor=none;" value="&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;width:100%; border-collapse: collapse; text-align: left;&quot;&gt; &lt;thead&gt; &lt;tr&gt;&lt;th colspan=&quot;4&quot; style=&quot;text-align: center; background-color: rgb(240, 240, 240);&quot;&gt;Orders&lt;/th&gt;&lt;/tr&gt; &lt;tr style=&quot;background-color: rgb(250, 250, 250);&quot;&gt;&lt;th&gt;Атрибут&lt;/th&gt;&lt;th&gt;Описание&lt;/th&gt;&lt;th&gt;Тип&lt;/th&gt;&lt;th&gt;Ограничения&lt;/th&gt;&lt;/tr&gt; &lt;/thead&gt; &lt;tbody&gt; &lt;tr&gt;&lt;td&gt;&lt;b&gt;order_id&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Идентификатор заказа&lt;/td&gt;&lt;td&gt;SERIAL&lt;/td&gt;&lt;td&gt;PRIMARY KEY&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;sender_id&lt;/td&gt;&lt;td&gt;ID отправителя&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Clients), NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;receiver_id&lt;/td&gt;&lt;td&gt;ID получателя&lt;/td&gt;&lt;td&gt;INT&lt;/td&gt;&lt;td&gt;FOREIGN KEY (Clients), NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;volume&lt;/td&gt;&lt;td&gt;Объем груза&lt;/td&gt;&lt;td&gt;NUMERIC(10, 2)&lt;/td&gt;&lt;td&gt;&amp;gt; 0, NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;product_type&lt;/td&gt;&lt;td&gt;Тип груза&lt;/td&gt;&lt;td&gt;VARCHAR(100)&lt;/td&gt;&lt;td&gt;NOT NULL, IN (&#39;standard&#39;, &#39;fragile&#39;, &#39;perishable&#39;, &#39;oversized&#39;, &#39;hazardous&#39;)&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;delivery_cost&lt;/td&gt;&lt;td&gt;Стоимость доставки&lt;/td&gt;&lt;td&gt;DECIMAL&lt;/td&gt;&lt;td&gt;&amp;gt;= 0, NOT NULL&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;order_date&lt;/td&gt;&lt;td&gt;Дата оформления&lt;/td&gt;&lt;td&gt;TIMESTAMP&lt;/td&gt;&lt;td&gt;NOT NULL,&amp;nbsp;DEFAULT CURRENT_TIMESTAMP&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt;&lt;td&gt;status&lt;/td&gt;&lt;td&gt;Статус заказа&lt;/td&gt;&lt;td&gt;VARCHAR(50)&lt;/td&gt;&lt;td&gt;NOT NULL, IN (&#39;created&#39;, &#39;in_progress&#39;, &#39;delivered&#39;, &#39;canceled&#39;)&lt;/td&gt;&lt;/tr&gt; &lt;/tbody&gt; &lt;/table&gt;" vertex="1">
